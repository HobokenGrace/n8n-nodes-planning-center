{
  "name": "n8n-nodes-planning-center",
  "version": "1.0.2",
  "description": "Community node package for n8n that integrates with Planning Center.",
  "keywords": ["n8n-community-node-package", "planning-center"],
  "license": "MIT",
  "homepage": "https://github.com/ZoneMix/n8n-nodes-planning-center.git",
  "author": {
    "name": "Bailey Belisario",
    "email": "zonemix@zonemix.tech"
  },
  "contributors": ["Nathan Cho <ntcho13@gmail.com>"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hobokengrace/n8n-nodes-planning-center.git"
  },
  "engines": {
    "node": "=22"
  },
  "main": "index.js",
  "scripts": {
    "build": "npx rimraf dist && tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && npm run lint -c .eslintrc.prepublish.js nodes credentials package.json"
  },
  "files": ["dist"],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": ["dist/credentials/PlanningCenterOAuth2Api.credentials.js"],
    "nodes": ["dist/nodes/PlanningCenter/PlanningCenter.node.js"]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@planningcenter/icons": "^15.25.3",
    "@typescript-eslint/parser": "~8.32.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^5.0.0",
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "overrides": {
    "n8n-workflow": {
      "form-data": "4.0.4"
    }
  }
}
